{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simmer",
  "version": "0.1.0",
  "identifier": "nz.simmer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Simmer",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]

    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png"
    ] 
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:simmer.db"]
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}